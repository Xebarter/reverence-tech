# Copy to .env and fill in. Never commit real .env.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: comma-separated origins for order API CORS
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Hosted checkout (Network International merchant credentials)
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
HOSTED_CHECKOUT_COMPANY_TOKEN=
HOSTED_CHECKOUT_SERVICE_TYPE=
# Optional overrides:
# HOSTED_CHECKOUT_CURRENCY=UGX
# HOSTED_CHECKOUT_API_URL=https://secure.3gdirectpay.com/API/v6/
# HOSTED_CHECKOUT_PAY_URL=https://secure.3gdirectpay.com/payv2.php
# HOSTED_CHECKOUT_PTL_HOURS=24
