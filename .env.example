# Copy to .env and fill in. Never commit real .env.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Leave unset or false for production
# VITE_DPO_TEST_MODE=false

# Used by Vercel / local serverless (not VITE_ prefix)
# production (default) = refuse sandbox hosts; sandbox = allow secure*.sandbox.directpay.online etc.
DPO_MERCHANT_MODE=production
DPO_COMPANY_TOKEN=
DPO_SERVICE_TYPE=
DPO_API_URL=https://secure.3gdirectpay.com/API/v6/
# Use the exact hosted page DPO gave you; `token` in their sample is only a placeholder — omit it here.
DPO_PAYMENT_URL=https://secure.3gdirectpay.com/payv3.php?ID=
DPO_BACK_URL=https://yourdomain.com/api/dpo/callback

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: comma-separated origins for payment API CORS
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
